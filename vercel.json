{
  "version": 2,
  "builds": [
    {
      "src": "api/generate-appeal.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/generate-appeal",
      "dest": "/api/generate-appeal.js"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/([a-zA-Z0-9_-]+\\.html)",
      "dest": "/public/$1"
    },
    {
      "src": "/favicon\\.png",
      "dest": "/public/favicon.png"
    }
  ]
}
